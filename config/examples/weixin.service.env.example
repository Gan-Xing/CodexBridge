# CodexBridge WeChat service environment

# Explicit account selection. If omitted, the runtime auto-picks the only saved account.
WEIXIN_ACCOUNT_ID=

# Policy
WEIXIN_DM_POLICY=open
WEIXIN_GROUP_POLICY=disabled
WEIXIN_ALLOWED_USERS=
WEIXIN_GROUP_ALLOWED_USERS=
WEIXIN_MAX_MESSAGE_LENGTH=4000

# Default Codex provider profile for new sessions.
CODEX_DEFAULT_PROVIDER_PROFILE_ID=openai-default

# Recommended even when codex is already on PATH.
CODEX_REAL_BIN=/home/ubuntu/.nvm/versions/node/v24.11.1/bin/codex

# Optional proxy profile exposure for MiniMax or other Codex-compatible backends.
# CODEX_CLI_BIN=/home/ubuntu/dev/telegram-codex-app-bridge/scripts/codex-via-cliproxy.sh
# CODEX_PROVIDER_ID=cliproxyminimax
# CODEX_PROVIDER_NAME=CLIProxyAPI MiniMax
# CODEX_PROVIDER_BASE_URL=http://127.0.0.1:8320/api/provider/minimax-codex/v1
# CODEX_PROVIDER_DEFAULT_MODEL=MiniMax-M2.7
# CODEX_MODEL_CATALOG_PATH=/home/ubuntu/dev/telegram-codex-app-bridge/config/codex-model-catalog.minimax.json
# CLIPROXY_CODEX_API_KEY=

# Optional Agent planner/verifier API. This does not replace Codex login;
# it only improves /agent draft normalization and semantic verification.
# For OpenAI-compatible providers such as MiniMax, keep chat_completions mode.
# CODEXBRIDGE_AGENT_API_KEY=
# CODEXBRIDGE_AGENT_BASE_URL=https://api.minimax.io/v1
# CODEXBRIDGE_AGENT_MODEL=MiniMax-M2.7
# CODEXBRIDGE_AGENT_API=chat_completions

# Debugging
CODEXBRIDGE_DEBUG_WEIXIN=0
